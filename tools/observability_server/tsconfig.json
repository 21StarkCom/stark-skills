{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2023"],
    "types": ["node"],
    "resolveJsonModule": true
  },
  "include": ["./server/**/*.ts", "./test/**/*.ts"]
}
