# Caddy reverse proxy for LAN access.
#
# Terminates TLS using the mkcert-issued cert under /certs and proxies to
# the Node observability server on the internal Compose network at
# observability:7799. The Node server enforces OBSERVABILITY_TLS_TERMINATED=1
# + X-Forwarded-Proto: https; removing this sidecar breaks the only path
# that supplies those signals, surfacing the misconfiguration immediately
# instead of silently downgrading to plain HTTP.
{
    # No automatic HTTPS — mkcert provides the cert we want.
    auto_https off
    admin off
}

:7700 {
    tls /certs/lan.crt /certs/lan.key
    reverse_proxy observability:7799 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For   {client_ip}
        header_up Host              {host}
    }
}
