graph TD
    A["CLI: /stark-metrics $ARGS"] --> B["metrics.py invoked"]
    B --> C["Load history/*.json"]
    C --> D{"History exists?"}
    D -- "No" --> E["Exit 1: No data"]
    D -- "Yes" --> F["Normalize formats"]
    F --> G["Apply filters: --repo, --skill, --since"]
    G --> H{"Records match?"}
    H -- "No" --> I["Empty report: broaden criteria"]
    H -- "Yes" --> J["Aggregate metrics"]
    J --> K["Agent scorecards"]
    J --> L["Finding quality"]
    J --> M["Duration trends"]
    J --> N["Prompt impact"]
    K & L & M & N --> O{"--json flag?"}
    O -- "Yes" --> P["JSON output"]
    O -- "No" --> Q["Terminal report"]
    Q --> R["Highlight Recommendations"]
    R --> S{"User picks action?"}
    S -- "Prompt tuning" --> T["/stark-review-improvement"]
    S -- "Config change" --> U["Edit config.json"]
    S -- "Skip" --> V["Improvement flags"]
    T & U --> V
    V --> W{"First run?"}
    W -- "Yes" --> X["Tip: run periodically"]
    V --> Y{"FP rate improved?"}
    Y -- "Yes" --> Z["Flag as win"]
    V --> AA{"Failure rate climbing?"}
    AA -- "Yes" --> AB["Flag as urgent"]

    style A fill:#e5e7eb,stroke:#9ca3af,color:#666
    style B fill:#1e40af,stroke:#1e40af,color:#fff
    style C fill:#1e40af,stroke:#1e40af,color:#fff
    style D fill:#7c3aed,stroke:#7c3aed,color:#fff
    style E fill:#dc2626,stroke:#dc2626,color:#fff
    style F fill:#1e40af,stroke:#1e40af,color:#fff
    style G fill:#047857,stroke:#047857,color:#fff
    style H fill:#7c3aed,stroke:#7c3aed,color:#fff
    style I fill:#dc2626,stroke:#dc2626,color:#fff
    style J fill:#1e40af,stroke:#1e40af,color:#fff
    style O fill:#7c3aed,stroke:#7c3aed,color:#fff
    style P fill:#f59e0b,stroke:#f59e0b,color:#1a1a1a
    style Q fill:#f59e0b,stroke:#f59e0b,color:#1a1a1a
    style R fill:#1e40af,stroke:#1e40af,color:#fff
    style S fill:#7c3aed,stroke:#7c3aed,color:#fff
    style T fill:#047857,stroke:#047857,color:#fff
    style U fill:#047857,stroke:#047857,color:#fff
    style V fill:#1e40af,stroke:#1e40af,color:#fff