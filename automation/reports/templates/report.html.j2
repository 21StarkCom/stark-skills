<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Automation Fleet Report — Week {{ week }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; max-width: 800px; margin: 2rem auto; padding: 0 1rem; color: #24292e; }
  h1 { border-bottom: 1px solid #e1e4e8; padding-bottom: 0.5rem; }
  table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
  th, td { border: 1px solid #e1e4e8; padding: 0.5rem; text-align: left; }
  th { background: #f6f8fa; }
  tr:nth-child(even) { background: #fafbfc; }
  .pass { color: #22863a; } .fail { color: #cb2431; }
  .alert { background: #fffbdd; border-left: 3px solid #f9c513; padding: 0.5rem 1rem; margin: 0.5rem 0; }
  footer { color: #6a737d; font-size: 0.875rem; margin-top: 2rem; border-top: 1px solid #e1e4e8; padding-top: 0.5rem; }
</style>
</head>
<body>
<h1>Automation Fleet Report &mdash; Week {{ week }}</h1>
<table>
<thead><tr><th>Trigger</th><th>Runs</th><th>Est. Tokens</th><th>Est. Cost</th><th>Avg Duration</th><th>Status</th></tr></thead>
<tbody>
{% for t in triggers -%}
<tr><td>{{ t.name }}</td><td>{{ t.runs }}</td><td>{{ "{:,}".format(t.tokens) }}</td><td>${{ "%.2f"|format(t.cost) }}</td><td>{{ t.avg_duration }}s</td><td class="{{ t.status|lower }}">{{ t.status }}</td></tr>
{% endfor -%}
<tr><td><strong>Total</strong></td><td><strong>{{ total_runs }}</strong></td><td><strong>{{ "{:,}".format(total_tokens) }}</strong></td><td><strong>${{ "%.2f"|format(total_cost) }}</strong></td><td></td><td></td></tr>
</tbody>
</table>
{% if alerts %}
<h2>Alerts</h2>
{% for alert in alerts -%}
<div class="alert">{{ alert }}</div>
{% endfor %}
{% endif %}
<footer>Generated by stark-automation-monitor</footer>
</body>
</html>
