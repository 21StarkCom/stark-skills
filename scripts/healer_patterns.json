[
  {
    "id": "auth-stale",
    "category": "AUTH_STALE",
    "regex": "(401|Bad credentials|token expired)",
    "guard": "security find-generic-password -s STARK_CLAUDE_PRIVATE_KEY -w",
    "action": "refresh_token",
    "verify_command": "node --experimental-strip-types tools/github_app.ts token",
    "requires_confirmation": false,
    "max_per_session": 1
  },
  {
    "id": "missing-import",
    "category": "MISSING_IMPORT",
    "regex": "No module named '([^']+)'",
    "guard": "python3 -c 'import sys; sys.exit(0)'",
    "action": "add_import",
    "verify_command": "python3 -c 'import {module}'",
    "requires_confirmation": true,
    "allowlisted_packages": ["json", "os", "sys", "pathlib", "re", "functools", "datetime", "uuid", "sqlite3", "subprocess", "shutil", "time", "collections", "typing", "dataclasses"]
  },
  {
    "id": "syntax-error",
    "category": "SYNTAX_ERROR",
    "regex": "(SyntaxError|IndentationError)",
    "guard": null,
    "action": "fix_syntax",
    "verify_command": "python3 -c 'compile(open(\"{file}\").read(), \"{file}\", \"exec\")'",
    "requires_confirmation": false
  },
  {
    "id": "migration-conflict",
    "category": "MIGRATION_CONFLICT",
    "regex": "(alembic.*revision|duplicate.*migration)",
    "guard": "ls migrations/versions/ 2>/dev/null",
    "action": "resolve_migration_head",
    "verify_command": "alembic heads",
    "requires_confirmation": true
  },
  {
    "id": "stale-lock",
    "category": "RESOURCE_EXHAUSTED",
    "regex": "(lock.*held|database.*locked|file.*locked)",
    "guard": null,
    "action": "release_stale_lock",
    "verify_command": "ls",
    "requires_confirmation": false
  },
  {
    "id": "ts-missing-type-export",
    "category": "TYPE_ERROR",
    "regex": "has no exported member '([^']+)'|Cannot find name '([^']+)'",
    "guard": "ls tsconfig.json 2>/dev/null",
    "action": "add_type_export",
    "verify_command": "npx tsc --noEmit 2>&1 | head -5",
    "requires_confirmation": true
  },
  {
    "id": "ts-unused-import",
    "category": "SYNTAX_ERROR",
    "regex": "'([^']+)' is declared but.*never used",
    "guard": "ls tsconfig.json 2>/dev/null",
    "action": "remove_unused_import",
    "verify_command": "npx tsc --noEmit 2>&1 | head -5",
    "requires_confirmation": false
  },
  {
    "id": "ts-strict-null",
    "category": "TYPE_ERROR",
    "regex": "Object is possibly '(null|undefined)'|Type '.*null.*' is not assignable",
    "guard": null,
    "action": "add_null_check",
    "verify_command": "npx tsc --noEmit 2>&1 | head -5",
    "requires_confirmation": true
  }
]
