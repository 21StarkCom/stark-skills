{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stark-insights.local/event/v2",
  "title": "Stark Event",
  "description": "Canonical event envelope for all stark-skills telemetry producers. Aligned with the stark-insights events table schema.",
  "type": "object",
  "required": ["type", "timestamp", "cli", "source", "schema_version", "payload"],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "description": "Event type discriminator.",
      "enum": [
        "skill_invocation",
        "review_finding",
        "review_quality",
        "agent_dispatch",
        "prompt",
        "correction",
        "memory_write",
        "code_change",
        "bug_fix",
        "pr_event",
        "tool_usage",
        "ci_signal",
        "tournament_result",
        "preflight_check",
        "approach_contract"
      ]
    },
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (uuid4). Present in schema_version >= 2 events."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 when the event occurred."
    },
    "cli": {
      "type": "string",
      "enum": ["claude", "codex", "gemini"],
      "description": "Which CLI produced the event."
    },
    "user_id": {
      "type": "string",
      "description": "GitHub username (canonical). Nullable for anonymous/unresolved."
    },
    "project": {
      "type": "string",
      "description": "Repo path or name."
    },
    "session_id": {
      "type": "string",
      "description": "CLI session identifier. Nullable for scraped events."
    },
    "source": {
      "type": "string",
      "enum": ["skill", "hook", "scraper", "backfill"],
      "description": "How the event was produced."
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Payload schema version. Starts at 1, bumped on breaking changes."
    },
    "dedupe_key": {
      "type": "string",
      "description": "Source-stable idempotency key. Formula varies by source: skill={skill}:{session_id}:{start_timestamp}, hook={cli}:{session_id}:{sequence_number}, scraper={cli}:{file_path}:{byte_offset}."
    },
    "payload": {
      "type": "object",
      "description": "Type-specific data. Schema depends on the event type."
    }
  }
}
