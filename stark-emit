#!/usr/bin/env bash
# Emit skill completion events to stark-insights via durable local queue.
#
# Usage: stark-emit <event_type> [key=value ...]
#
# Designed for skill SKILL.md instructions — Claude runs this at the end
# of a skill invocation to log structured outcomes.
#
# Thin shell wrapper that builds the payload JSON and shells into the TS
# CLI (tools/emit_queue_cli.ts). The TS lib persists the event into
# ~/.stark-insights/queue.db; stark-insights' scheduler drains it.
#
# Differences from hook-emit.py:
#   - Sets source=skill for proper dedupe key computation
#   - Reads CLAUDE_SESSION_ID + CLAUDE_PROJECT for session/project linkage
#   - Coerces true/false → bool, numeric strings → int/float in payload
set -euo pipefail

if [ $# -lt 1 ]; then
    exit 0
fi

EVENT_TYPE="$1"
shift

# Locate the TS CLI: prefer the installed symlink, fall back to repo-local
CLI=""
if [ -f "$HOME/.claude/code-review/tools/emit_queue_cli.ts" ]; then
    CLI="$HOME/.claude/code-review/tools/emit_queue_cli.ts"
else
    here="$(cd "$(dirname "$0")" && pwd)"
    if [ -f "$here/tools/emit_queue_cli.ts" ]; then
        CLI="$here/tools/emit_queue_cli.ts"
    fi
fi
[ -n "$CLI" ] || exit 0  # no CLI reachable — silently drop, matching prior shim

# Build the payload JSON from key=value args, coercing true/false/int/float.
PAYLOAD=$(python3 - "$@" <<'PYEOF'
import json, sys

def coerce(v):
    if v.lower() == "true": return True
    if v.lower() == "false": return False
    try: return int(v)
    except ValueError: pass
    try: return float(v)
    except ValueError: pass
    return v

out = {}
for arg in sys.argv[1:]:
    if "=" in arg:
        k, v = arg.split("=", 1)
        out[k] = coerce(v)
print(json.dumps(out))
PYEOF
)

ARGS=(node --experimental-strip-types --no-warnings "$CLI" enqueue
      --type "$EVENT_TYPE" --payload "$PAYLOAD" --source skill --cli claude)

if [ -n "${CLAUDE_SESSION_ID:-}" ]; then
    ARGS+=(--session-id "$CLAUDE_SESSION_ID")
fi
if [ -n "${CLAUDE_PROJECT:-}" ]; then
    ARGS+=(--project "$CLAUDE_PROJECT")
fi

# Best-effort: telemetry failures must never break the caller.
"${ARGS[@]}" >/dev/null 2>&1 || true
