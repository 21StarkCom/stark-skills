#!/usr/bin/env python3
"""Emit skill completion events to stark-insights via durable local queue.

Usage: stark-emit <event_type> [key=value ...]

Designed for skill SKILL.md instructions — Claude runs this at the end
of a skill invocation to log structured outcomes.

Events are written to a local SQLite queue (~/.stark-insights/queue.db)
and drained to the API opportunistically. Events survive container
restarts and network interruptions.

Differences from hook-emit.py:
  - Sets source=skill for proper dedupe key computation
  - Reads CLAUDE_SESSION_ID for session linkage
  - Coerces CLI values: true/false→bool, numeric strings→int/float
"""

import os
import sys

# Add scripts/ to path for emit_queue import
sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), "scripts"))

from emit_queue import enqueue, make_event


def _coerce(v: str) -> bool | int | float | str:
    if v.lower() == "true":
        return True
    if v.lower() == "false":
        return False
    try:
        return int(v)
    except ValueError:
        pass
    try:
        return float(v)
    except ValueError:
        pass
    return v


def main() -> None:
    if len(sys.argv) < 2:
        return

    event_type = sys.argv[1]
    payload: dict[str, bool | int | float | str] = {}
    for arg in sys.argv[2:]:
        if "=" in arg:
            k, v = arg.split("=", 1)
            payload[k] = _coerce(v)

    session_id = os.environ.get("CLAUDE_SESSION_ID")
    project = os.environ.get("CLAUDE_PROJECT", "")

    event = make_event(
        event_type,
        payload,
        cli="claude",
        source="skill",
        session_id=session_id,
        project=project or None,
    )

    try:
        enqueue(event)
    except ValueError:
        pass  # validation error — skip silently for backward compat
    # No drain here: stark-insights' scheduler owns the drain side; events
    # are durable in queue.db until it picks them up.


if __name__ == "__main__":
    main()
