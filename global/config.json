{
  "agents": ["claude", "codex"],
  "domain_agents": {
    "architecture": "codex",
    "accessibility": "codex",
    "correctness": "codex",
    "type-safety": "codex",
    "security": "codex",
    "test-coverage": "codex",
    "spec-conformance": "codex",
    "ui-design-conformance": "codex",
    "regression-prevention": "codex"
  },
  "fix_threshold": "medium",
  "test_command": null,
  "build_command": null,
  "verify_before_clean": true,
  "disabled_domains": [],
  "extra_domains": [],
  "context_files": [],
  "severity_overrides": {},
  "github_apps": {
    "claude": "stark-claude",
    "codex": "stark-codex",
    "gemini": "stark-gemini"
  },
  "session": {
    "health_checks": [],
    "build_command": null,
    "test_command": null,
    "doc_paths": ["docs/", "CLAUDE.md"],
    "devlog_path": null,
    "pr_merge_strategy": "squash"
  },
  "plan_to_tasks": {
    "validation_agents": ["codex"],
    "max_quality_gate_rounds": 3,
    "max_validation_iterations": 2
  },
  "models": {
    "claude": { "enabled": true, "model_id": "claude-sonnet-4-6" },
    "codex": { "enabled": true, "model_id": "gpt-5.4" },
    "gemini": { "enabled": false, "model_id": "gemini-2.5-pro" }
  },
  "runtime": {
    "lock_ttl_minutes": 30,
    "subagent_env_allowlist": [
      "PATH", "HOME", "USER", "SHELL", "LANG", "TERM",
      "CLAUDE_CODE_USE_VERTEX", "ANTHROPIC_VERTEX_PROJECT_ID", "CLOUD_ML_REGION",
      "GOOGLE_APPLICATION_CREDENTIALS"
    ],
    "max_concurrent_agents": 3,
    "temp_dir_prefix": "stark-env"
  },
  "self_heal": {
    "enabled": true,
    "mode": "suggest",
    "max_auto_retries": 0,
    "patterns_file": "healer_patterns.json",
    "circuit_breaker_threshold": 3,
    "auto_patterns": []
  },
  "validation_gate": {
    "enabled": true,
    "run_on": ["implementation", "autopilot"],
    "skip_domains": [],
    "timeout_seconds": 60
  },
  "skill_activation": {
    "enabled": true,
    "suggest_after_review_rounds": 3,
    "max_suggestions": 2,
    "cooldown_hours": 24,
    "suppressed_skills": [],
    "activation_signals": ["review_finding", "correction", "skill_invocation"]
  },
  "context_compaction": {
    "enabled": true,
    "checkpoint_interval_minutes": 15,
    "max_checkpoint_size_kb": 50,
    "include_file_summaries": true
  },
  "graph_enriched_domains": ["architecture", "correctness", "regression-prevention"],
  "graph_gate_mode": "disabled",
  "cost": {
    "weekly_budget_usd": 50.0,
    "daily_alert_usd": 15.0,
    "hard_stop_usd": 100.0,
    "track_rolling_7d": true
  },
  "triage": {
    "mode": "conservative",
    "agent": "claude",
    "timeout": 15,
    "conservative_confidence_threshold": 0.8,
    "insights_url": "http://localhost:7420"
  },
  "design_review": {
    "agents": ["claude", "codex"],
    "fix_threshold": "medium",
    "disabled_domains": [],
    "max_rounds": 3,
    "triage": {
      "mode": "conservative"
    }
  },
  "plan_review": {
    "triage": {
      "mode": "conservative"
    }
  },
  "automation": {
    "model": "claude-sonnet-4-6",
    "repos": [
      "GetEvinced/stark-skills",
      "GetEvinced/infra-pulse",
      "GetEvinced/infra-ai-platform",
      "GetEvinced/infra-sentinel",
      "GetEvinced/stark-team",
      "GetEvinced/stark-data-core"
    ],
    "connectors": {
      "slack": "cf414024-1eec-4f23-8b5d-c6c0eb4b100e",
      "context7": "088e0653-356a-4362-8b07-bd93b9acabbb"
    },
    "github_app_ids": {
      "claude": { "app_id": 3066738, "installation_id": 115648521 },
      "codex":  { "app_id": 3066834, "installation_id": 115650994 },
      "gemini": { "app_id": 3066689, "installation_id": 115648971 }
    },
    "cost_alert_threshold_usd_per_week": 50.0,
    "slack_channel": "#stark-automation",
    "triggers": {
      "stark-evolution":           { "cron": "0 3 * * 0",  "tier": 1, "budget_usd": 10.0 },
      "stark-self-review":         { "cron": "0 6 * * 1",  "tier": 1, "budget_usd": 5.0 },
      "stark-sentinel":            { "cron": "0 5 * * 0-3,5-6", "tier": 2, "budget_usd": 1.0 },
      "stark-dependency-audit":    { "cron": "0 4 * * 2",  "tier": 2, "budget_usd": 3.0 },
      "stark-infra-drift":         { "cron": "0 6 * * *",  "tier": 2, "budget_usd": 1.0 },
      "stark-api-compat":          { "cron": "0 7 * * *",  "tier": 2, "budget_usd": 1.0 },
      "stark-intelligence":        { "cron": "0 6 * * 3",  "tier": 3, "budget_usd": 3.0 },
      "stark-claude-md-sync":      { "cron": "0 4 * * 4",  "tier": 3, "budget_usd": 2.0 },
      "stark-digest":              { "cron": "0 14 * * 5", "tier": 4, "budget_usd": 2.0 },
      "stark-observability-check": { "cron": "0 8 * * *",  "tier": 4, "budget_usd": 1.0 },
